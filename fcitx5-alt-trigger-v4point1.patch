--- a/src/lib/fcitx/inputmethodengine.h
+++ b/src/lib/fcitx/inputmethodengine.h
@@ -205,6 +205,31 @@ public:
                              VirtualKeyboardEvent &VirtualKeyboardEvent) = 0;
 };
 
+/**
+ * @brief Input Method Engine V4.1 interface
+ * @since 5.2.0
+ *
+ * Extends InputMethodEngineV4 with support for controlling altTrigger behavior.
+ * Engines that handle Shift_L themselves (e.g., Rime for Chinese/English toggle)
+ * can override supportsAltTrigger() to return false.
+ */
+class FCITXCORE_EXPORT InputMethodEngineV4Point1 : public InputMethodEngineV4 {
+public:
+    /**
+     * @brief Whether this engine supports Fcitx5's altTrigger (Shift_L toggle)
+     * @return true to enable altTrigger (default), false to disable
+     * @since 5.2.0
+     */
+    virtual bool supportsAltTrigger() const { return true; }
+
+    /**
+     * @brief Default implementation for V4.1 engines
+     * Forwards to keyEvent() for backward compatibility
+     */
+    void virtualKeyboardEventImpl(const InputMethodEntry &entry,
+                                  VirtualKeyboardEvent &event) override;
+};
+
 } // namespace fcitx
 
 #endif // _FCITX_INPUTMETHODENGINE_H_
