diff --git a/src/lib/fcitx/inputmethodengine.cpp b/src/lib/fcitx/inputmethodengine.cpp
index 83787083..ddd677f3 100644
--- a/src/lib/fcitx/inputmethodengine.cpp
+++ b/src/lib/fcitx/inputmethodengine.cpp
@@ -83,4 +83,17 @@ void InputMethodEngineV4::virtualKeyboardEventImpl(const InputMethodEntry &,
     throw std::logic_error("Not implemented virtualKeyboardEventImpl");
 }
 
+void InputMethodEngineV4Point1::virtualKeyboardEventImpl(
+    const InputMethodEntry &entry, VirtualKeyboardEvent &event) {
+    // Default V4.1 implementation: forward to keyEvent
+    if (auto virtualKeyEvent = event.toKeyEvent()) {
+        keyEvent(entry, *virtualKeyEvent);
+        if (virtualKeyEvent->accepted()) {
+            event.accept();
+        } else if (!event.text().empty()) {
+            event.inputContext()->commitString(event.text());
+        }
+    }
+}
+
 } // namespace fcitx
diff --git a/src/lib/fcitx/inputmethodengine.h b/src/lib/fcitx/inputmethodengine.h
